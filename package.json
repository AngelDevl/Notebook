{
  "name": "notebook",
  "version": "1.0.0",
  "description": "A simple notebook app to manage notes.",
  "packageManager": "npm@11.4.2",
  "scripts": {
    "dev": "turbo run dev",
    "dev:backend": "turbo run dev --filter=backend",
    "dev:frontend": "turbo run dev --filter=frontend",
    "build": "turbo run build",
    "start": "docker compose up -d --build",
    "test": "turbo run test"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AngelDevl/Notebook.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/AngelDevl/Notebook/issues"
  },
  "homepage": "https://github.com/AngelDevl/Notebook#readme",
  "devDependencies": {
    "turbo": "latest"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
