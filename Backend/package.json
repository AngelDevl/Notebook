{
  "name": "backend",
  "version": "1.0.0",
  "main": "src/index.ts",
  "type": "module",
  "scripts": {
    "dev": "cross-env NODE_ENV=development tsx watch src/index.ts",
    "test": "cross-env NODE_ENV=test tsx watch src/index.ts",

    "build": "tsc",
    "start": "node dist/index.js",
    "deploy": "cross-env NODE_ENV=production npm run gen && npm run migrate && npm run start",
    "dev:run": "cross-env NODE_ENV=development npm run gen && npm run dev:migrate && npm run dev",
    "test:run": "cross-env NODE_ENV=test npm run gen && npm run dev:migrate && npm run start",
    "gen": "npx prisma generate --config ./src/prisma.config.ts",
    "migrate": "npx prisma migrate deploy --config ./src/prisma.config.ts",
    "dev:create": "npx prisma migrate dev --create-only --config ./src/prisma.config.ts",
    "dev:migrate": "prisma migrate dev --name init --config ./src/prisma.config.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.19.2",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.2.1",
    "http-status-codes": "^2.3.0",
    "joi": "^18.0.2",
    "pino": "^10.3.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.3.5",
    "cross-env": "^10.1.0",
    "nodemon": "^3.1.14",
    "pino-pretty": "^13.1.3",
    "prisma": "^6.19.2",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
