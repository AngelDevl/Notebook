{
  "name": "backend",
  "version": "1.0.0",
  "main": "src/index.ts",
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/index.js",
    "gen": "npx prisma generate --config ./src/prisma.config.ts",
    "migrate": "npx prisma migrate deploy --config ./src/prisma.config.ts",
    "gen:prod": "npx prisma generate --config ./dist/prisma.config.js",
    "migrate:prod": "npx prisma migrate deploy --config ./dist/prisma.config.js",
    "deploy": "npm run gen:prod && npm run migrate:prod && npm run start",
    "test": "npm run test:up && node --experimental-vm-modules node_modules/jest/bin/jest.js -i --silent && npm run test:down",
    "test:up": "docker compose -f ../docker-compose.test.yml --env-file ../.env.test up -d --build",
    "test:down": "docker compose -f ../docker-compose.test.yml down",
    "dev": "cross-env NODE_ENV=development tsx watch src/index.ts",
    "dev:up": "docker compose -f ../docker-compose.dev.yml --env-file ../.env.development up -d --build postgres",
    "dev:down": "docker compose -f ../docker-compose.dev.yml down",
    "dev:run": "npm run dev:up && cross-env NODE_ENV=development npm run gen && npm run dev:migrate && npm run dev",
    "dev:create": "npx prisma migrate dev --create-only --config ./src/prisma.config.ts",
    "dev:migrate": "prisma migrate dev --name init --config ./src/prisma.config.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.19.2",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.2.1",
    "http-status-codes": "^2.3.0",
    "joi": "^18.0.2",
    "pino": "^10.3.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.3.5",
    "@types/supertest": "^7.2.0",
    "axios": "^1.13.6",
    "cross-env": "^10.1.0",
    "jest": "^30.3.0",
    "jest-mock-extended": "^4.0.0",
    "nodemon": "^3.1.14",
    "pino-pretty": "^13.1.3",
    "prisma": "^6.19.2",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
